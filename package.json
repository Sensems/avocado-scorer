{
  "name": "avocado-scorer-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "大仓架构 - 牛油果记分牌",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:server": "pnpm --filter server dev",
    "migration:run": "pnpm --filter server migration:run",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "format": "prettier --write \"**/*.{js,ts,vue,json,md}\"",
    "clean": "pnpm -r exec rm -rf node_modules dist .turbo"
  },
  "keywords": [
    "monorepo",
    "pnpm",
    "vue3",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "typescript": "^5.0.0",
    "prettier": "^3.0.0"
  }
}
